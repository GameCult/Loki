{
  "manifest_version": 3,
  "name": "Loki Chrome Bridge",
  "version": "0.1.0",
  "description": "Publishes Chrome tab metadata to the local Loki CultMesh daemon.",
  "permissions": [
    "alarms",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:17666/*",
    "http://localhost:17666/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Loki Chrome Bridge",
    "default_popup": "popup.html"
  }
}
